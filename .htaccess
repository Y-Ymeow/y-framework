<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. 禁止访问敏感目录和文件
    RewriteRule ^(\.env|composer\.json|composer\.lock|Caddyfile|FRAMEWORK_PLAN.md|README.md) - [F,L]
    RewriteRule ^(app|bin|bootstrap|config|database|docs|functions|routes|src|storage|tests|vendor)($|/) - [F,L]

    # 2. 如果请求的是存在的静态文件，直接访问 public 目录
    RewriteCond %{DOCUMENT_ROOT}/public/$1 -f
    RewriteRule ^(.*)$ public/$1 [L]

    # 3. 其他所有请求转发给 index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [L,QSA]
</IfModule>

# 禁止目录列表
Options -Indexes
