{
  "name": "ymeow/framework",
  "description": "Full-featured application skeleton. Anti-MVC, route-first, component-driven.",
  "type": "project",
  "version": "0.2.0-dev",
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "psr/log": "^3.0",
    "psr/simple-cache": "^3.0",
    "symfony/cache": "^7.0",
    "symfony/console": "^7.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Framework\\": "framework/",
      "Admin\\": "admin/",
      "App\\": "app/",
      "Modules\\": "modules/",
      "Support\\": "support/",
      "Database\\": "database/",
      "Services\\": "services/",
      "Jobs\\": "jobs/",
      "Queue\\": "queue/",
      "Commands\\": "commands/"
    },
    "files": [
      "framework/Support/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "serve": "php -S 127.0.0.1:8000 -t public public/index.php"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}