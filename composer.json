{
  "name": "ymeow/php-framework",
  "description": "Anti-MVC, route-first, component-driven PHP framework.",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "monolog/monolog": "^3.0",
    "psr/simple-cache": "^3.0",
    "symfony/cache": "^7.0",
    "symfony/console": "^7.0",
    "symfony/http-foundation": "^7.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Framework\\": "src/",
      "App\\": "app/",
      "Admin\\": "admin/"
    },
    "files": [
      "src/Support/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "serve": "php -S 127.0.0.1:8000 -t public public/index.php"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
